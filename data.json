  "day_guide": {
    "1": {
      "phase": "Glycogen Depletion",
      "expect": "Hunger peaks, possible headache. Body using stored glucose. Weight drops from water/glycogen.",
      "tips": "Stay hydrated. Electrolytes help. Keep busy.",
      "metabolic": "Your liver is burning through its 100g glycogen reserve (~400 calories). Each gram of glycogen binds 3-4g of water, so you'll lose 1-2kg of water weight rapidly. Insulin levels are dropping, signaling kidneys to excrete sodium (causing electrolyte flush). Ghrelin (hunger hormone) peaks as your body expects food. Blood glucose maintained around 70-80 mg/dL through gluconeogenesis. Cortisol and adrenaline slightly elevated to mobilize energy stores.",
      "electrolytes": {
        "sodium": "½-¾ tsp salt",
        "potassium": "¼-½ tsp NoSalt",
        "magnesium": "1 pill (400mg)",
        "note": "Critical day - glycogen loss pulls water and electrolytes. Salt your water."
      }
    },
